{
  "name": "lavaca-app",
  "version": "0.1.0",
  "private": true,
  "description": "La Vaca 🐄 - Simple y sencillo de dividir y pagar cuentas",
  "scripts": {
    "dev": "pnpm --filter @lavaca/frontend start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build:web": "pnpm --filter @lavaca/frontend exec expo export --platform web",
    "db:seed": "supabase db reset --debug",
    "db:seed:only": "supabase db seed"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {}
}
